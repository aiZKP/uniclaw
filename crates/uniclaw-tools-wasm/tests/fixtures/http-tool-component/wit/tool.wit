// Mirror of `crates/uniclaw-tools-wasm/wit/tool.wit`. cargo-component
// resolves the WIT package from this directory; keeping a copy here
// avoids reaching outside the fixture crate's directory tree (which
// cargo-component handles awkwardly across workspace boundaries).
//
// If you change the host WIT, update this copy too.

package uniclaw:tool@0.1.0;

interface tool-api {
    call: func(input: list<u8>) -> result<list<u8>, string>;
}

interface host {
    enum log-level {
        trace,
        debug,
        info,
        warn,
        error,
    }

    record http-response {
        status: u16,
        headers: list<tuple<string, string>>,
        body: list<u8>,
    }

    variant auth-spec {
        bearer-header(string),
    }

    log-message: func(level: log-level, message: string);
    now-millis: func() -> u64;
    secret-exists: func(name: string) -> bool;
    http-fetch: func(
        url: string,
        auth: option<auth-spec>,
        timeout-ms: option<u32>,
    ) -> result<http-response, string>;
}

world tool {
    export tool-api;
}

world tool-with-host {
    import host;
    export tool-api;
}
